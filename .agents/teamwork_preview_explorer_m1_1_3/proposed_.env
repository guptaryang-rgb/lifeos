# PostgreSQL database URL for Prisma connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifeos?schema=public"

# NextAuth.js Secret for session signing and encryption (generate a secure random key in production)
NEXTAUTH_SECRET="super-secret-nextauth-encryption-key-for-local-dev-12345"

# NextAuth.js App URL (standard Next.js local development address)
NEXTAUTH_URL="http://localhost:3000"
